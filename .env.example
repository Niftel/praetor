# Copy to .env and adjust for your machine. .env is gitignored.

# Connection string for running the Go services directly (outside Docker)
# against the dockerized database. Match the host DB port below if you change it.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/praetor?sslmode=disable

# Host ports published by `docker compose`. The defaults match the QUICKSTART;
# override only if one collides with another service on your machine.
# PRAETOR_UI_PORT=3000
# PRAETOR_API_PORT=8080
# PRAETOR_DB_PORT=5432
# PRAETOR_WEB1_PORT=8081

# Secrets (REQUIRED — services refuse to boot without them; compose supplies dev
# defaults so the stack still comes up locally). Override both in any real
# deployment.
#   PRAETOR_SECRET_KEY  encrypts credentials / notification URLs / Galaxy tokens
#                       at rest. MUST be exactly 32 bytes.
#   JWT_SECRET          signs API auth tokens.
# PRAETOR_SECRET_KEY=change-me-to-a-random-32-byte-key
# JWT_SECRET=change-me-to-a-long-random-string
#
# Key rotation: set PRAETOR_SECRET_KEY to the NEW key and PRAETOR_SECRET_KEY_OLD
# to the previous one. Decryption falls back to the old key, so existing data
# stays readable while it is re-encrypted under the new key.
# PRAETOR_SECRET_KEY_OLD=
#
# Local dev only: skip the required-secret check and use the built-in insecure
# defaults instead of setting the vars above.
# PRAETOR_ALLOW_INSECURE_DEFAULTS=true
